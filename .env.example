# Application Port
PORT=3000

# Node Environment
NODE_ENV=development

# Database Configuration (PostgreSQL)
# Adjust these for your local docker or local postgres instance
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ledger?schema=public"

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Configuration
JWT_SECRET=super-secret-jwt-key-replace-in-production
JWT_REFRESH_SECRET=super-secret-jwt-refresh-key-replace-in-production
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
